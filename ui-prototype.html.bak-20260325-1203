});

// 搜索框实时过滤
document.addEventListener('DOMContentLoaded', () => {
  const searchInput = document.querySelector('.filter-search input');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      searchQuery = this.value.trim().toLowerCase();
      applyFilter();
