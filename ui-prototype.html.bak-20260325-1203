  const url = window.location.href.split('#')[0] + '#player';
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(() => showToast('✓ 链接已复制到剪贴板', 'success'));
  } else {
    // 降级：创建临时 input
    const tmp = document.createElement('input');
    tmp.value = url;
    document.body.appendChild(tmp);
    tmp.select();
    document.execCommand('copy');
    document.body.removeChild(tmp);
    showToast('✓ 链接已复制', 'success');
  }
}

/* ════════════════════════════════════════════
   播放/暂停
════════════════════════════════════════════ */
let playing = false;
let playTimer = null;

function togglePlay() {
  playing = !playing;
  const btn  = document.getElementById('playBtn');
  const icon = document.getElementById('playIcon');
  if (playing) {
    icon.innerHTML = '<rect x="3" y="2" width="4" height="12" rx="1" fill="currentColor"/><rect x="9" y="2" width="4" height="12" rx="1" fill="currentColor"/>';
    btn.setAttribute('aria-label','暂停');
    btn.style.background   = '#059669';
    btn.style.borderColor  = '#059669';
    playTimer = setInterval(() => {
      if (currentStep < totalSteps) {
        nextStep();
      } else {
        togglePlay();
        showToast('✓ 播放完成，已自动重置', 'success');
        setTimeout(() => gotoStep(1), 600);
      }
    }, 1800);
  } else {
    icon.innerHTML = '<polygon points="4,2 13,8 4,14" fill="currentColor"/>';
    btn.setAttribute('aria-label','播放');
    btn.style.background  = 'var(--blue-500)';
    btn.style.borderColor = 'var(--blue-500)';
    clearInterval(playTimer);
  }
}

/* ════════════════════════════════════════════
   步骤状态
════════════════════════════════════════════ */
let currentStep = 1;
const totalSteps = 3;

/* ════════════════════════════════════════════
   步骤跳转 / 渲染
════════════════════════════════════════════ */
function gotoStep(step) {
  currentStep = Math.max(1, Math.min(totalSteps, step));
  renderStep();
}
function nextStep() { if (currentStep < totalSteps) gotoStep(currentStep + 1); }
function prevStep() { if (currentStep > 1) gotoStep(currentStep - 1); }

function renderStep() {
  const data = stepData[currentStep - 1];

  /* ── 进度条 ── */
  const pct = (currentStep / totalSteps) * 100;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('stepLabel').textContent = `第 ${currentStep} 步 / 共 ${totalSteps} 步`;

  /* ── 连接状态横幅 ── */
  const banner = document.querySelector('.conn-banner');
  banner.innerHTML = data.bannerText;
  if (data.bannerClass === 'banner-success') {
    banner.style.background    = 'rgba(16,185,129,0.08)';
    banner.style.borderColor   = 'rgba(16,185,129,0.25)';
    banner.style.color         = 'var(--green-400)';
  } else {
    banner.style.background    = 'var(--cyan-subtle)';
    banner.style.borderColor   = 'rgba(34,211,238,0.18)';
    banner.style.color         = 'var(--cyan-400)';
  }

  /* ── 节点状态 ── */
  const cs = document.getElementById('client-state');
  cs.textContent = data.clientState;
  cs.className   = 'node-state ' + data.clientClass;

  const ss = document.getElementById('server-state');
  ss.textContent = data.serverState;
  ss.className   = 'node-state ' + data.serverClass;

  /* ── 箭头行高亮 ── */
  for (let i = 1; i <= totalSteps; i++) {
    const row = document.getElementById('row-' + i);
    row.classList.remove('active', 'upcoming');
    if (i === data.activeRow) row.classList.add('active');
    else if (i > data.activeRow) row.classList.add('upcoming');
  }

  /* ── 进度圆点 ── */
  document.querySelectorAll('.step-dot').forEach((dot, i) => {
    dot.classList.remove('done', 'current');
    if (i < currentStep - 1) dot.classList.add('done');
    else if (i === currentStep - 1) dot.classList.add('current');
  });

  /* ── 层次一：步骤旁白联动 ── */
  const narrations = [
    `客户端随机选择初始序列号（ISN=${dynClientISN}），发送 SYN 报文向服务端请求建立连接。此时客户端进入 SYN_SENT 状态，等待服务端响应。SYN 标志位置 1 表示"我想和你建立连接"。`,
    `服务端收到 SYN，回复 SYN-ACK：用 ack=${dynClientISN+1} 确认客户端（= ${dynClientISN}+1），同时带上自己的初始序列号 seq=${dynServerISN}。这一步等于服务端说"我收到了，我也要跟你建连接"。`,
    `客户端收到 SYN-ACK，发出最后一个 ACK（ack=${dynServerISN+1} = ${dynServerISN}+1）。双方同时进入 ESTABLISHED 状态，TCP 连接正式建立，应用层可以开始传输数据！`,
  ];
  const narEl = document.getElementById('narrationText');
  if (narEl) {
    narEl.textContent = narrations[currentStep - 1];
    // 触发重新入场动画
    const narBox = document.getElementById('stepNarration');
    if (narBox) {
      narBox.style.animation = 'none';
      narBox.offsetHeight; // reflow
      narBox.style.animation = '';
    }
  }

  /* ── 层次一：知识点块动态联动 ── */
  const kb = document.getElementById('knowledgeBlock');
  if (kb && knowledgeData.length) {
    const kd = knowledgeData[currentStep - 1];
    kb.innerHTML = `<div class="knowledge-block-title">${kd.title}</div>${kd.body}`;
  }

  /* ── 层次二③：思考题联动 ── */
  const qBlock = document.getElementById('quizBlock');
  if (qBlock && quizData.length) {
    const qd = quizData[currentStep - 1];
    document.getElementById('quizQuestion').textContent = qd.q;
    const ans = document.getElementById('quizAnswer');
    ans.innerHTML = qd.a;
    ans.classList.remove('open');
    const btn = qBlock.querySelector('.quiz-toggle');
    if (btn) btn.textContent = '查看答案 ▾';
  }

  /* ── 右侧步骤卡片联动 ── */
  const stepCardEls = document.querySelectorAll('#tab-steps .step-card');
  stepCardEls.forEach((card, i) => {
    card.classList.remove('active', 'done');
    const numEl = card.querySelector('.step-num');
    if (i < currentStep - 1) {
      card.classList.add('done');
      numEl.innerHTML = '✓';
    } else if (i === currentStep - 1) {
      card.classList.add('active');
      numEl.textContent = i + 1;
      // 滚动到可见区
      card.scrollIntoView({ behavior:'smooth', block:'nearest' });
    } else {
      numEl.textContent = i + 1;
    }
    // 同步更新文案（可选，保持准确性）
    const sc = stepCards[i];
    card.querySelector('.step-title').textContent  = sc.title;
    card.querySelector('.step-desc').textContent   = sc.desc;
    card.querySelector('.step-packet').textContent = sc.packet;
  });

  /* ── 层次二①②：字段解析联动（含推导标注 + 高亮） ── */
  const fieldTitle = document.querySelector('.field-panel-title');
  if (fieldTitle) fieldTitle.textContent = data.fieldTitle;

  const tbody = document.querySelector('.field-table tbody');
  if (tbody) {
    tbody.innerHTML = data.fields.map(f => `
      <tr${f.highlight ? ' class="field-highlight"' : ''}>
        <td class="field-name">${f.name}</td>
        <td class="field-val">${f.val}</td>
        <td>${f.desc}${f.derive ? `<div class="field-derive">= ${f.derive}</div>` : ''}</td>
      </tr>
    `).join('');
  }

  /* ── ARIA ── */
  document.querySelector('.progress-track').setAttribute('aria-valuenow', currentStep);
}

function seekProgress(e) {
  const pct = e.offsetX / e.currentTarget.offsetWidth;
  gotoStep(Math.max(1, Math.min(totalSteps, Math.round(pct * totalSteps + 0.5))));
}

/* ════════════════════════════════════════════
   层次三①：异常场景遮罩
════════════════════════════════════════════ */
function showAbnormal() {
  document.getElementById('abnormalOverlay').classList.add('open');
}
function closeAbnormal() {
  document.getElementById('abnormalOverlay').classList.remove('open');
}

/* ════════════════════════════════════════════
   层次三②：TCP vs UDP 对照切换
════════════════════════════════════════════ */
let compareMode = false;
function toggleCompare() {
  compareMode = !compareMode;
  const tcp  = document.getElementById('tcpDiagram');
  const udp  = document.getElementById('udpDiagram');
  const nar  = document.getElementById('stepNarration');
  const btn  = document.getElementById('compareToggleBtn');
  if (compareMode) {
    tcp.style.display = 'none';
    udp.classList.add('visible');
    if (nar) nar.style.display = 'none';
    btn.style.background = 'var(--green-subtle)';
    btn.style.borderColor = 'rgba(52,211,153,0.4)';
    btn.style.color = 'var(--green-400)';
    showToast('已切换到 TCP vs UDP 对比视图', 'success');
  } else {
    tcp.style.display = '';
    udp.classList.remove('visible');
    if (nar) nar.style.display = '';
    btn.style.background = '';
    btn.style.borderColor = '';
    btn.style.color = '';
    showToast('已返回 TCP 三次握手视图', 'info');
  }
}

/* ════════════════════════════════════════════
   层次二③：思考题展开/收起
════════════════════════════════════════════ */
function toggleQuiz(btn) {
  const ans = document.getElementById('quizAnswer');
  if (ans.classList.contains('open')) {
    ans.classList.remove('open');
    btn.textContent = '查看答案 ▾';
  } else {
    ans.classList.add('open');
    btn.textContent = '收起答案 ▴';
  }
}

/* ════════════════════════════════════════════
   键盘快捷键
════════════════════════════════════════════ */
document.addEventListener('keydown', e => {
  const playerActive = document.getElementById('page-player').classList.contains('active');
  if (!playerActive) return;
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); nextStep(); }
  else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); prevStep(); }
  else if (e.key === ' ') { e.preventDefault(); togglePlay(); }
  else if (e.key === 'Escape') { closeAbnormal(); }
});

/* ════════════════════════════════════════════
   初始化
════════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  rebuildStepData();   // 生成动态数据
  renderStep();        // 初始渲染
});
</script>

