// 当前激活的筛选
let activeFilter = 'all';
let searchQuery  = '';

function applyFilter() {
  const allCards = document.querySelectorAll('#page-protocols .protocol-card');
  const sections = document.querySelectorAll('#page-protocols .list-section-title');

  allCards.forEach(card => {
    const layer  = card.dataset.layer  || '';
    const level  = card.dataset.level  || '';
    const title  = card.dataset.title  || '';

    const layerMatch = activeFilter === 'all'
      || activeFilter === layer
      || activeFilter === level;

    const searchMatch = searchQuery === ''
      || title.includes(searchQuery);

    const show = layerMatch && searchMatch;
    card.style.display = show ? '' : 'none';
  });

  // 如果某个分组全部隐藏，隐藏分组标题
  const grids = document.querySelectorAll('#page-protocols .list-grid');
  grids.forEach((grid, i) => {
    const visibleCards = grid.querySelectorAll('.protocol-card:not([style*="display: none"])');
    const sectionTitle = sections[i];
    const hidden = visibleCards.length === 0;
    if (sectionTitle) sectionTitle.style.display = hidden ? 'none' : '';
    grid.style.display = hidden ? 'none' : '';
  });

  // 空结果提示
  let emptyTip = document.getElementById('filter-empty');
  const allHidden = document.querySelectorAll('#page-protocols .protocol-card:not([style*="display: none"])').length === 0;
  if (allHidden) {
    if (!emptyTip) {
      emptyTip = document.createElement('div');
      emptyTip.id = 'filter-empty';
      emptyTip.style.cssText = 'text-align:center;padding:48px 0;color:var(--text-4);font-size:14px;';
      emptyTip.innerHTML = '<div style="font-size:32px;margin-bottom:12px">🔍</div>没有匹配的协议，换个关键词试试';
      document.querySelector('.list-content').appendChild(emptyTip);
    }
    emptyTip.style.display = '';
  } else if (emptyTip) {
    emptyTip.style.display = 'none';
  }
}

// 筛选标签点击
document.querySelectorAll('.filter-tag').forEach(tag => {
  tag.addEventListener('click', function() {
    document.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    activeFilter = this.dataset.filter || 'all';
