════════════════════════════════════════════ */
// 动态 seq/ack 值（默认 client=100, server=300）
let dynClientISN = 100;
let dynServerISN = 300;

function applyCustomSeq() {
  const c = parseInt(document.getElementById('customSeqInput').value, 10);
  const s = parseInt(document.getElementById('customSeqServer').value, 10);
  if (isNaN(c) || isNaN(s) || c < 0 || s < 0) {
    showToast('⚠️ 请输入有效的正整数序列号', 'error');
    return;
  }
  dynClientISN = c;
  dynServerISN = s;

  // 更新画布上的标签
  document.getElementById('lbl-seq1').textContent = c;
  document.getElementById('lbl-seq2').textContent = s;
  document.getElementById('lbl-ack2').textContent = c + 1;
  document.getElementById('lbl-seq3').textContent = c + 1;
  document.getElementById('lbl-ack3').textContent = s + 1;

  // 提示推导结果
  document.getElementById('seqHintText').innerHTML =
    `<span class="custom-seq-derived">ack₂ = ${c}+1 = ${c+1} &nbsp;｜&nbsp; ack₃ = ${s}+1 = ${s+1}</span>`;

  // 重新生成步骤数据并渲染
  rebuildStepData();
  renderStep();
  showToast(`✓ 已应用：客户端 ISN=${c}，服务端 ISN=${s}`, 'success');
}

/* ════════════════════════════════════════════
   步骤数据（支持动态 seq）
════════════════════════════════════════════ */
let stepData = [];
let stepCards = [];
let knowledgeData = [];
let quizData = [];

function rebuildStepData() {
  const c = dynClientISN;
  const s = dynServerISN;

  stepData = [
    {
      clientState:'SYN_SENT',    clientClass:'state-synsent',
      serverState:'LISTEN',      serverClass:'state-listen',
      activeRow:1,
      bannerText:`🔗 第 1 / 3 步 — 客户端发起连接请求…`,
      bannerClass:'',
      fieldTitle:`当前数据包字段（SYN）`,
      fields:[
        { name:'SYN',      val:'1',           desc:'同步序号，请求建立连接',                          highlight:false, derive:'' },
        { name:'ACK',      val:'0',           desc:'确认位无效（首次握手）',                          highlight:false, derive:'' },
        { name:'seq',      val:`${c}`,        desc:`客户端随机初始序列号 ISN`,                       highlight:true,  derive:`随机生成，防止序列号预测攻击` },
        { name:'ack',      val:'0',           desc:'尚未确认，值为 0',                               highlight:false, derive:'' },
        { name:'Window',   val:'65535',       desc:'客户端接收窗口大小（字节）',                     highlight:false, derive:'' },
        { name:'Src Port', val:'52341',       desc:'客户端临时端口（随机）',                         highlight:false, derive:'' },
        { name:'Dst Port', val:'443',         desc:'目标端口（HTTPS 服务）',                        highlight:false, derive:'' },
        { name:'Checksum', val:'0x4a1f',      desc:'校验和，保证数据完整性',                         highlight:false, derive:'' },
      ],
    },
    {
      clientState:'SYN_SENT',    clientClass:'state-synsent',
      serverState:'SYN_RCVD',    serverClass:'state-synrcvd',
      activeRow:2,
      bannerText:`🔗 第 2 / 3 步 — 服务端确认，双向同步中…`,
      bannerClass:'',
      fieldTitle:`当前数据包字段（SYN-ACK）`,
      fields:[
        { name:'SYN',      val:'1',           desc:'同步序号，服务端请求建立连接',                   highlight:false, derive:'' },
        { name:'ACK',      val:'1',           desc:'确认位有效',                                    highlight:false, derive:'' },
        { name:'seq',      val:`${s}`,        desc:`服务端随机初始序列号 ISN`,                       highlight:true,  derive:`随机生成` },
        { name:'ack',      val:`${c+1}`,      desc:`= 客户端 seq(${c}) + 1`,                       highlight:true,  derive:`${c} + 1 = ${c+1}，表示"期望下一个收到的字节编号"` },
        { name:'Window',   val:'65535',       desc:'服务端接收窗口大小（字节）',                     highlight:false, derive:'' },
        { name:'Src Port', val:'443',         desc:'服务端源端口（HTTPS）',                         highlight:false, derive:'' },
        { name:'Dst Port', val:'52341',       desc:'客户端临时端口',                                 highlight:false, derive:'' },
        { name:'Checksum', val:'0x8f2a',      desc:'校验和，保证数据完整性',                         highlight:false, derive:'' },
      ],
    },
    {
      clientState:'ESTABLISHED', clientClass:'state-established',
      serverState:'ESTABLISHED', serverClass:'state-established',
      activeRow:3,
      bannerText:`✅ 连接已建立！双方进入 ESTABLISHED 状态`,
      bannerClass:'banner-success',
      fieldTitle:`当前数据包字段（ACK）`,
      fields:[
        { name:'SYN',      val:'0',           desc:'同步位关闭（非握手阶段）',                       highlight:false, derive:'' },
        { name:'ACK',      val:'1',           desc:'确认位有效',                                    highlight:false, derive:'' },
        { name:'seq',      val:`${c+1}`,      desc:`客户端序号前进`,                                highlight:true,  derive:`${c} + 1 = ${c+1}（SYN 报文消耗一个序号）` },
        { name:'ack',      val:`${s+1}`,      desc:`= 服务端 seq(${s}) + 1`,                       highlight:true,  derive:`${s} + 1 = ${s+1}，确认服务端 SYN` },
        { name:'Window',   val:'65535',       desc:'客户端接收窗口大小（字节）',                     highlight:false, derive:'' },
        { name:'Src Port', val:'52341',       desc:'客户端临时端口',                                 highlight:false, derive:'' },
        { name:'Dst Port', val:'443',         desc:'目标端口（HTTPS 服务）',                        highlight:false, derive:'' },
