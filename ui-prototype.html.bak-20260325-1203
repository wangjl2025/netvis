  stepCards = [
    {
      title:'第 1 步：客户端发送 SYN',
      desc:`客户端向服务端发送 SYN 报文，请求建立连接。随机选择初始序列号 ISN=${c}，进入 SYN_SENT 状态，等待服务端响应。`,
      packet:`SYN=1, seq=${c}`,
    },
    {
      title:'第 2 步：服务端回复 SYN-ACK',
      desc:`服务端收到 SYN，回复 SYN-ACK。用 ack=${c+1} 确认客户端（= ${c}+1），同时带上自己的初始序列号 seq=${s}，进入 SYN_RCVD 状态。`,
      packet:`SYN=1, ACK=1, seq=${s}, ack=${c+1}`,
    },
    {
      title:'第 3 步：客户端发送 ACK',
      desc:`客户端用 ack=${s+1} 确认服务端序列号（= ${s}+1）。双方进入 ESTABLISHED，连接正式建立，可以开始传输数据。`,
